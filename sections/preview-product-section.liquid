            }
          }, {
            "type": "product_card",
            "settings": {
              "product_title": "Hydrating Serum",
              "product_description": "Lightweight, fast-absorbing hydration boost",
              "product_price": "$65.00",
              "category_label": "Active",
              "badge_shape": "triangle",
              "show_rating": true,
              "rating_count": "203"
            }
          }, {
            "type": "product_card",
            "settings": {
              "product_title": "Brightening Essence",
              "product_description": "Illuminating treatment for radiant skin",
              "product_price": "$82.00",
              "category_label": "Balance",
              "badge_shape": "oval",
              "show_rating": true,
              "rating_count": "89"
            }
          }
        ]
      }
    ],
    "max_blocks": 12
  }
{% endschema %}