<section class="preview-product-section-{{ section.id }} w-full full-width flex justify-center py-12 mx-auto md:py-32 bg-white">
  <div class="max-w-7xl mx-auto px-4 md:px-8">

    {%- if section.settings.heading != blank -%}
      <div class="flex items-center justify-center py-20 gap-3">
        <h2 class="font-serif text-2xl md:text-5xl text-center font-normal text-gray-900" style="color: {{ section.settings.heading_color }};">
          {{ section.settings.heading }}
        </h2>
      </div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="grid grid-cols-1 md:grid-cols-2 justify-center lg:grid-cols-3 gap-4 ">

        {%- for block in section.blocks -%}
          {%- assign product_ref = all_products[block.settings.product] -%}

            <div {{ block.shopify_attributes }} class=" bg-white rounded-xs overflow-hidden shadow-sm hover:shadow-md transition-shadow duration-300">

            {%- comment -%} Image container with category badge {%- endcomment -%}
            <div class="relative aspect-3/4 bg-gray-100 overflow-hidden">
              <a
                href="{%- if product_ref != blank -%}{{ product_ref.url }}{%- elsif block.settings.product_url != blank -%}{{ block.settings.product_url }}{%- else -%}#{%- endif -%}"
                class="block w-full h-full"
                aria-label="{{ block.settings.product_title | default: product_ref.title | escape }}">

                {%- if product_ref != blank and product_ref.featured_image -%}
                  {{ product_ref.featured_image
 | image_url: width: 800
 | image_tag:
 loading: 'lazy',
 widths: '400, 600, 800',
 class: 'w-full h-full object-cover group-hover:scale-105 transition-transform duration-500',
 alt: product_ref.featured_image.alt | default: product_ref.title | escape
                  }}
                {%- elsif block.settings.product_image -%}
                  {{ block.settings.product_image
 | image_url: width: 800
 | image_tag:
 loading: 'lazy',
 widths: '400, 600, 800',
 class: 'w-full h-full object-cover group-hover:scale-105 transition-transform duration-500',
 alt: block.settings.product_title | escape
                  }}
                {%- elsif block.settings.product_image_url != blank -%}
                  <img
                    src="{{ block.settings.product_image_url }}"
                    loading="lazy"
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                    alt="{{ block.settings.product_title | escape }}">
                {%- else -%}
                  <div class="w-full h-full bg-gray-200 flex items-center justify-center">
                    <span class="text-gray-400 text-sm">No image</span>
                  </div>
                {%- endif -%}
              </a>

              {%- comment -%} Category badge - top left with shape {%- endcomment -%}
              {%- if block.settings.category_label != blank -%}
                <div class="absolute top-4 left-4 flex items-center gap-3">
                  {%- comment -%} Shape icon {%- endcomment -%}
                  {%- assign badge_shape = block.settings.badge_shape | default: 'square' -%}

                  {%- if badge_shape == 'square' -%}
                    <div class="w-4 h-4 shrink-0" style="background-color: {{ section.settings.accent_color }};"></div>
                  {%- elsif badge_shape == 'rectangle' -%}
                    <div class="w-12 h-6 shrink-0" style="background-color: {{ section.settings.accent_color }};"></div>
                  {%- elsif badge_shape == 'triangle' -%}
                    <div class="w-0 h-0 shrink-0" style="border-left: 10px solid transparent; border-right: 10px solid transparent; border-bottom: 18px solid {{ section.settings.accent_color }};"></div>
                  {%- elsif badge_shape == 'oval' -%}
                    <div class="w-4 h-4 shrink-0 rounded-full" style="background-color: {{ section.settings.accent_color }};"></div>
                  {%- endif -%}

                  {%- comment -%} Label text {%- endcomment -%}
                  <span class="text-lg md:text-xl font-normal tracking-wide" style="color: {{ section.settings.accent_color }};">
                    {{ block.settings.category_label }}
                  </span>
                </div>
              {%- endif -%}

              {%- comment -%} Add to cart button - bottom right {%- endcomment -%}
              <div class="absolute bottom-4 right-4">
                {%- if product_ref != blank -%}
                  <button
                    type="button"
                    class="group w-12 h-12 rounded-xs bg-white flex items-center justify-center hover:bg-[#241EC6] transition-transform duration-200"
                    aria-label="Add {{ product_ref.title | escape }} to cart"
                    data-product-id="{{ product_ref.variants.first.id }}">
                    <span class="w-5 h-5 text-gray-900 group-hover:text-white transition-colors duration-200">{% render 'icon-cart' %}</span>
                  </button>
                {%- else -%}
                  <button
                    type="button"
                    class="group w-12 h-12 rounded-xs bg-white flex items-center justify-center hover:bg-[#241EC6] transition-transform duration-200"
                    aria-label="Add {{ block.settings.product_title | escape }} to cart">
                    <span class="w-5 h-5 text-gray-900 group-hover:text-white transition-colors duration-200">{% render 'icon-cart' %}</span>
                  </button>
                {%- endif -%}
              </div>
            </div>

            {%- comment -%} Product info {%- endcomment -%}
            <div class=" p-5 flex flex-col gap-3">
              <div class="flex flex-col">
                <h3 class="text-lg md:text-xl font-normal text-gray-900 mb-2 leading-tight">
                  {%- if product_ref != blank -%}
                    {{ product_ref.title }}
                  {%- else -%}
                    {{ block.settings.product_title }}
                  {%- endif -%}
                </h3>

                <p class="text-sm text-gray-500 mb-3 leading-relaxed">
                  {%- if product_ref != blank and product_ref.description != blank -%}
                    {{ product_ref.description | strip_html | truncate: 80 }}
                  {%- else -%}
                    {{ block.settings.product_description }}
                  {%- endif -%}
                </p>
              </div>
              <div class="flex flex-row justify-between">
                {%- comment -%} Rating stars {%- endcomment -%}
                {%- if block.settings.show_rating -%}
                  <div class="flex items-center gap-2 mb-3">
                    <div class="flex items-center gap-0.5">
                      {%- for i in (1..5) -%}
                        <svg
                          class="w-4 h-4"
                          style="fill: {{ section.settings.accent_color }};"
                          viewBox="0 0 20 20"
                          xmlns="http://www.w3.org/2000/svg">
                          <path d="M10 15l-5.878 3.09 1.123-6.545L.489 6.91l6.572-.955L10 0l2.939 5.955 6.572.955-4.756 4.635 1.123 6.545z" />
                        </svg>
                      {%- endfor -%}
                    </div>
                    {%- if block.settings.rating_count != blank -%}
                      <span class="text-xs text-gray-500">({{ block.settings.rating_count }})</span>
                    {%- endif -%}
                  </div>
                {%- endif -%}
                {%- comment -%} Price {%- endcomment -%}
                <div class="text-xl font-medium text-gray-900">
                  {%- if product_ref != blank -%}
                    {{ product_ref.price | money_without_trailing_zeros }}
                  {%- else -%}
                    {{ block.settings.product_price }}
                  {%- endif -%}
                </div>
              </div>
            </div>

          </div>
        {%- endfor -%}

      </div>
    {%- endif -%}

  </div>
</section>

<script>
  (function() {
  'use strict';
  
  if (typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') return;
  
  gsap.registerPlugin(ScrollTrigger);
  
  const section = document.querySelector('.preview-product-section-{{ section.id }}');
  if (!section) return;
  
  const mm = gsap.matchMedia();
  
  mm.add({
    isDesktop: '(min-width: 1024px)',
    isTablet: '(min-width: 768px) and (max-width: 1023px)',
    isMobile: '(max-width: 767px)',
    reduceMotion: '(prefers-reduced-motion: reduce)'
  }, (context) => {
    const { isDesktop, isTablet, isMobile, reduceMotion } = context.conditions;
    
    const yDistance = isMobile ? 30 : isTablet ? 40 : 40;
    const duration = reduceMotion ? 0 : (isMobile ? 0.6 : 0.8);
    const staggerDelay = reduceMotion ? 0 : (isMobile ? 0.1 : 0.15);
    
    // Fade in heading
    const heading = section.querySelector('h2');
    if (heading) {
      gsap.from(heading, {
        opacity: reduceMotion ? 1 : 0,
        y: reduceMotion ? 0 : yDistance,
        duration: duration,
        ease: 'power2.out',
        scrollTrigger: {
          trigger: heading,
          start: isMobile ? 'top 85%' : 'top 80%',
          toggleActions: 'play none none none'
        }
      });
    }
    
    // Stagger product cards
    const cards = section.querySelectorAll('.grid > div');
    if (cards.length > 0) {
      gsap.from(cards, {
        opacity: reduceMotion ? 1 : 0,
        y: reduceMotion ? 0 : (isMobile ? 40 : 60),
        duration: duration,
        stagger: staggerDelay,
        ease: 'power2.out',
        scrollTrigger: {
          trigger: section.querySelector('.grid'),
          start: isMobile ? 'top 80%' : 'top 75%',
          toggleActions: 'play none none none'
        }
      });
    }
  });
  
  })();
</script>

{% schema %}
  {
    "name": "Preview Product Section",
    "settings": [
      {
        "type": "color",
        "id": "background_color",
        "label": "Background Color",
        "default": "#f5f5f0"
      }, {
        "type": "text",
        "id": "heading",
        "label": "Section Heading",
        "default": "Renew",
        "info": "The ECHMA Collection"
      }, {
        "type": "color",
        "id": "heading_color",
        "label": "Heading Color",
        "default": "#6366f1"
      }, {
        "type": "color",
        "id": "accent_color",
        "label": "Accent Color",
        "default": "#4f46e5"
      }
    ],
    "blocks": [
      {
        "type": "product_card",
        "name": "Product Card",
        "settings": [
          {
            "type": "product",
            "id": "product",
            "label": "Product",
            "info": "Select a product — title, description, price and image will be pulled automatically"
          },
          {
            "type": "header",
            "content": "Manual Override (used when no product is selected)"
          },
          {
            "type": "image_picker",
            "id": "product_image",
            "label": "Product Image"
          },
          {
            "type": "text",
            "id": "product_image_url",
            "label": "Product Image URL",
            "info": "External image URL — used when no Shopify image is selected above"
          }, {
            "type": "text",
            "id": "product_title",
            "label": "Product Title",
            "default": "Renewal Cream"
          }, {
            "type": "textarea",
            "id": "product_description",
            "label": "Product Description",
            "default": "Smoothing, strengthening daily moisturizer"
          }, {
            "type": "text",
            "id": "product_price",
            "label": "Price (manual)",
            "default": "$75.00",
            "info": "Used only when no product is selected above"
          }, {
            "type": "url",
            "id": "product_url",
            "label": "Product URL (manual)",
            "info": "Used only when no product is selected above"
          }, {
            "type": "text",
            "id": "category_label",
            "label": "Category Label",
            "default": "Renew",
            "info": "Badge displayed on top-left of image"
          }, {
            "type": "select",
            "id": "badge_shape",
            "label": "Badge Shape",
            "options": [
              {
                "value": "square",
                "label": "Square"
              }, {
                "value": "rectangle",
                "label": "Rectangle"
              }, {
                "value": "triangle",
                "label": "Triangle"
              }, {
                "value": "oval",
                "label": "Oval"
              }
            ],
            "default": "square",
            "info": "Choose the shape icon for the badge"
          }, {
            "type": "checkbox",
            "id": "show_rating",
            "label": "Show Rating Stars",
            "default": true
          }, {
            "type": "text",
            "id": "rating_count",
            "label": "Rating Count",
            "default": "116",
            "info": "Number displayed next to stars"
          }
        ]
      }
    ],
    "presets": [
      {
        "name": "Preview Product Section",
        "category": "Products",
        "blocks": [
          {
            "type": "product_card",
            "settings": {
              "product_title": "Renewal Cream",
              "product_description": "Smoothing, strengthening daily moisturizer",
              "product_price": "$75.00",
              "category_label": "Renew",
              "badge_shape": "square",
