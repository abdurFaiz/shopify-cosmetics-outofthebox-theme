{% comment %} 
                                                                                                            Hero Section - Cosmetics Product Showcase (Tailwind CSS v4)
{% endcomment %}

<section
  class="full-width relative w-full h-screen min-h-[600px] overflow-hidden"
  style="padding-top:0;"
  id="hero-section">
  {%- comment -%} Multiple background images - one for each nav item {%- endcomment -%}
  <div class="absolute inset-0 z-1">
    {%- comment -%} Image 1 - Renew {%- endcomment -%}
    {% if section.settings.image_1 %}
      <img
        src="{{ section.settings.image_1 | image_url: width: 1920 }}"
        alt="Hero background 1"
        loading="eager"
        class="hero-image active w-full h-full object-cover object-center"
        data-index="0"
        width="1920"
        height="1080">
    {% else %}
      <img
        src="https://cdn.shopify.com/s/files/1/0814/5217/1522/files/hero-image.jpg?v=1776594704"
        alt="Hero background 1"
        loading="eager"
        class="hero-image active w-full h-full object-cover object-center"
        data-index="0"
        width="1920"
        height="1080">
    {% endif %}

    {%- comment -%} Image 2 - Activate {%- endcomment -%}
    {% if section.settings.image_2 %}
      <img
        src="{{ section.settings.image_2 | image_url: width: 1920 }}"
        alt="Hero background 2"
        loading="eager"
        class="hero-image w-full h-full object-cover object-center"
        data-index="1"
        width="1920"
        height="1080"
        style="opacity:0;">
    {% else %}
      <img
        src="https://cdn.shopify.com/s/files/1/0814/5217/1522/files/hero-image-2.jpg?v=1776601609"
        alt="Hero background 2"
        loading="eager"
        class="hero-image w-full h-full object-cover object-center"
        data-index="1"
        width="1920"
        height="1080"
        style="opacity:0;">
    {% endif %}

    {%- comment -%} Image 3 - Balance {%- endcomment -%}
    {% if section.settings.image_3 %}
      <img
        src="{{ section.settings.image_3 | image_url: width: 1920 }}"
        alt="Hero background 3"
        loading="eager"
        class="hero-image w-full h-full object-cover object-center"
        data-index="2"
        width="1920"
        height="1080"
        style="opacity:0;">
    {% else %}
      <img
        src="https://cdn.shopify.com/s/files/1/0814/5217/1522/files/hero-image-3.jpg?v=1776601615"
        alt="Hero background 3"
        loading="eager"
        class="hero-image w-full h-full object-cover object-center"
        data-index="2"
        width="1920"
        height="1080"
        style="opacity:0;">
    {% endif %}
  </div>

  {%- comment -%} Gradient overlay — left to right transition {%- endcomment -%}
  <div class="absolute inset-0 pointer-events-none" style="z-index:1;background:linear-gradient(to right, rgba(0,0,0,0.5) 0%, rgba(0,0,0,0.25) 40%, transparent 80%);"></div>

  <div class="relative h-full flex flex-col justify-between px-6 py-10 md:px-10 md:py-8 lg:px-12 lg:py-10 w-full" style="z-index:2;">

    <!-- Navigation Items - Absolute positioned left, near center -->
    <nav
      class="absolute left-6 md:left-10 lg:left-12 top-1/2 flex flex-col gap-3 md:gap-4 items-start"
      style="transform:translateY(-50%);"
      aria-label="Product navigation">

      {%- comment -%} Nav Item 1 — filled square (active indicator) {%- endcomment -%}
      {% if section.settings.nav_item_1 != blank %}
        <button
          class="nav-btn group bg-transparent border-none text-white font-sans text-[13px] md:text-sm font-normal tracking-wide cursor-pointer p-0 transition-colors duration-300 text-left relative pl-5 md:pl-6 active"
          data-index="0"
          type="button">
          {%- comment -%} Filled square = active {%- endcomment -%}
          <span
            class="nav-indicator absolute left-0 top-1/2 -translate-y-1/2 bg-white"
            aria-hidden="true"
            style="width:9px;height:9px;display:block;"></span>
          {{ section.settings.nav_item_1 }}
        </button>
      {% endif %}

      {%- comment -%} Nav Item 2 — hollow circle {%- endcomment -%}
      {% if section.settings.nav_item_2 != blank %}
        <button
          class="nav-btn group bg-transparent border-none text-white/60 font-sans text-[13px] md:text-sm font-normal tracking-wide cursor-pointer p-0 transition-colors duration-300 text-left relative pl-5 md:pl-6 hover:text-white"
          data-index="1"
          type="button">
          {%- comment -%} Hollow circle {%- endcomment -%}
          <span
            class="nav-indicator absolute left-0 top-1/2 -translate-y-1/2 rounded-full transition-all duration-300 group-hover:border-white"
            aria-hidden="true"
            style="width:9px;height:9px;display:block;border:1px solid rgba(255,255,255,0.6);background:transparent;"></span>
          {{ section.settings.nav_item_2 }}
        </button>
      {% endif %}

      {%- comment -%} Nav Item 3 — hollow triangle (CSS only, no SVG) {%- endcomment -%}
      {% if section.settings.nav_item_3 != blank %}
        <button
          class="nav-btn group bg-transparent border-none text-white/60 font-sans text-[13px] md:text-sm font-normal tracking-wide cursor-pointer p-0 transition-colors duration-300 text-left relative pl-5 md:pl-6 hover:text-white"
          data-index="2"
          type="button">
          {%- comment -%} CSS triangle using border trick — no SVG, no clip-path rendering issues {%- endcomment -%}
          <span
            class="nav-indicator absolute left-0 top-1/2 -translate-y-1/2 transition-all duration-300"
            aria-hidden="true"
            style="width:0;height:0;display:block;border-left:4.5px solid transparent;border-right:4.5px solid transparent;border-bottom:8px solid rgba(255,255,255,0.6);"></span>
          {{ section.settings.nav_item_3 }}
        </button>
      {% endif %}

    </nav>

    <!-- Text Content — changes with nav -->
    <div class="flex-1 flex flex-col justify-end max-w-3xl">
      {%- comment -%} Content Set 1 - Renew {%- endcomment -%}
      <div class="content-set active" data-index="0">
        {% if section.settings.subtitle_1 != blank %}
          <p class="text-white/90 font-sans text-[13px] md:text-[15px] lg:text-base font-normal leading-relaxed m-0 mb-1.5 md:mb-2 tracking-[0.02em]">
            {{ section.settings.subtitle_1 }}
          </p>
        {% endif %}
        {% if section.settings.title_1 != blank %}
          <h1 class="text-white font-serif text-[42px] md:text-5xl lg:text-6xl xl:text-[72px] font-normal leading-[1.05] m-0 tracking-tight">
            {{ section.settings.title_1 }}
          </h1>
        {% endif %}
      </div>

      {%- comment -%} Content Set 2 - Activate {%- endcomment -%}
      <div
        class="content-set"
        data-index="1"
        style="display:none;">
        {% if section.settings.subtitle_2 != blank %}
          <p class="text-white/90 font-sans text-[13px] md:text-[15px] lg:text-base font-normal leading-relaxed m-0 mb-1.5 md:mb-2 tracking-[0.02em]">
            {{ section.settings.subtitle_2 }}
          </p>
        {% endif %}
        {% if section.settings.title_2 != blank %}
          <h1 class="text-white font-serif text-[42px] md:text-5xl lg:text-6xl xl:text-[72px] font-normal leading-[1.05] m-0 tracking-tight">
            {{ section.settings.title_2 }}
          </h1>
        {% endif %}
      </div>

      {%- comment -%} Content Set 3 - Balance {%- endcomment -%}
      <div
        class="content-set"
        data-index="2"
        style="display:none;">
        {% if section.settings.subtitle_3 != blank %}
          <p class="text-white/90 font-sans text-[13px] md:text-[15px] lg:text-base font-normal leading-relaxed m-0 mb-1.5 md:mb-2 tracking-[0.02em]">
            {{ section.settings.subtitle_3 }}
          </p>
        {% endif %}
        {% if section.settings.title_3 != blank %}
          <h1 class="text-white font-serif text-[42px] md:text-5xl lg:text-6xl xl:text-[72px] font-normal leading-[1.05] m-0 tracking-tight">
            {{ section.settings.title_3 }}
          </h1>
        {% endif %}
      </div>
    </div>

    <!-- Product Card - Above CTA button -->
    <div class="absolute right-6 md:right-8 lg:right-12" style="bottom: 90px;">
      {%- comment -%} Card 1 - Renew {%- endcomment -%}
      <div
        class="testimonial-card active bg-white shadow-sm overflow-hidden"
        data-index="0"
        style="width:184px;">
        {%- comment -%} Product Image - Full width, no padding {%- endcomment -%}
        <div class="w-full bg-gray-100  flex items-center justify-center" style="height:250px; padding:8px">
          {% if section.settings.product_image_1 %}
            <img
              src="{{ section.settings.product_image_1 | image_url: width: 260 }}"
              alt="Product"
              class="w-full h-full object-contain">
          {% else %}
            <img
              src="https://cdn.shopify.com/s/files/1/0814/5217/1522/files/product-3.jpg?v=1776604855"
              alt="Product"
              class="w-full h-full object-contain">
          {% endif %}
        </div>

        {%- comment -%} Product Info - Padded below image {%- endcomment -%}
        <div class="px-4 pb-4" style="margin-bottom: 8px;">
          <h3 class="text-sm font-medium text-[#1a1a1a] leading-tight tracking-tight uppercase">
            {{ section.settings.product_name_1 | default: 'LIQUID BLUSH' }}
          </h3>
          <p class="text-xs text-gray-500 mb-3 tracking-wide">
            {{ section.settings.product_desc_1 | default: 'T01 - OPAL PINK' }}
          </p>
         
        </div>
      </div>

      {%- comment -%} Card 2 - Activate {%- endcomment -%}
      <div
        class="testimonial-card bg-white shadow-sm overflow-hidden hidden"
        data-index="1"
        style="width:184px;">
        <div class="w-full bg-gray-100  flex items-center justify-center" style="height:250px; padding:8px">
          {% if section.settings.product_image_2 %}
            <img
              src="{{ section.settings.product_image_2 | image_url: width: 560 }}"
              alt="Product"
              class="w-full h-full object-contain">
          {% else %}
            <img
              src="https://cdn.shopify.com/s/files/1/0814/5217/1522/files/product-1.jpg?v=1776604826"
              alt="Product"
              class="w-full h-full object-contain">
          {% endif %}
        </div>
        <div class="px-4 pb-4" style="margin-bottom: 8px;">
          <h3 class="text-sm font-medium text-[#1a1a1a] leading-tight tracking-tight uppercase">
            {{ section.settings.product_name_2 | default: 'ACTIVATE SERUM' }}
          </h3>
          <p class="text-xs text-gray-500 mb-3 tracking-wide">
            {{ section.settings.product_desc_2 | default: 'Energizing Formula' }}
          </p>
        
        </div>
      </div>

      {%- comment -%} Card 3 - Balance {%- endcomment -%}
      <div
        class="testimonial-card bg-white shadow-sm overflow-hidden hidden"
        data-index="2"
        style="width:184px;">
        <div class="w-full bg-gray-100  flex items-center justify-center" style="height:250px; padding:8px">
          {% if section.settings.product_image_3 %}
            <img
              src="{{ section.settings.product_image_3 | image_url: width: 560 }}"
              alt="Product"
              class="w-full h-full object-contain">
          {% else %}
            <img
              src="https://cdn.shopify.com/s/files/1/0814/5217/1522/files/product-2.jpg?v=1776604840"
              alt="Product"
              class="w-full h-full object-contain">
          {% endif %}
        </div>
        <div class="px-4 pb-4" style="margin-bottom: 8px;">
          <h3 class="text-sm font-medium text-[#1a1a1a] leading-tight tracking-tight uppercase">
            {{ section.settings.product_name_3 | default: 'BALANCE TONER' }}
          </h3>
          <p class="text-xs text-gray-500 mb-3 tracking-wide">
            {{ section.settings.product_desc_3 | default: 'Calming Blend' }}
      
        </div>
      </div>
    </div>

    <!-- CTA Buttons - Absolute positioned bottom-right, changes with nav -->
    <div class="absolute bottom-6 right-6 md:bottom-8 md:right-8 lg:bottom-12 lg:right-12">
      {%- comment -%} CTA 1 - Renew {%- endcomment -%}
      <a
        href="{{ section.settings.cta_url_1 | default: '#' }}"
        class="cta-btn active inline-flex items-center gap-1.5 bg-white text-[#1a1a1a] font-sans text-[12px] md:text-[13px] font-medium no-underline px-5 py-2.5 md:px-6 md:py-3 rounded-sm transition-all duration-300 tracking-[0.08em] uppercase hover:bg-white/95 hover:-translate-y-0.5 hover:shadow-md"
        data-index="0">
        {{ section.settings.cta_label_1 | default: 'SHOP NOW' }}
        {% if section.settings.show_price and section.settings.price_1 != blank %}
          <span class="font-normal normal-case tracking-normal">– {{ section.settings.price_1 }}</span>
        {% endif %}
      </a>

      {%- comment -%} CTA 2 - Activate {%- endcomment -%}
      <a
        href="{{ section.settings.cta_url_2 | default: '#' }}"
        class="cta-btn inline-flex items-center gap-1.5 bg-white text-[#1a1a1a] font-sans text-[12px] md:text-[13px] font-medium no-underline px-5 py-2.5 md:px-6 md:py-3 rounded-sm transition-all duration-300 tracking-[0.08em] uppercase hover:bg-white/95 hover:-translate-y-0.5 hover:shadow-md"
        data-index="1"
        style="display:none;">
        {{ section.settings.cta_label_2 | default: 'SHOP NOW' }}
        {% if section.settings.show_price and section.settings.price_2 != blank %}
          <span class="font-normal normal-case tracking-normal">– {{ section.settings.price_2 }}</span>
        {% endif %}
      </a>

      {%- comment -%} CTA 3 - Balance {%- endcomment -%}
      <a
        href="{{ section.settings.cta_url_3 | default: '#' }}"
        class="cta-btn inline-flex items-center gap-1.5 bg-white text-[#1a1a1a] font-sans text-[12px] md:text-[13px] font-medium no-underline px-5 py-2.5 md:px-6 md:py-3 rounded-sm transition-all duration-300 tracking-[0.08em] uppercase hover:bg-white/95 hover:-translate-y-0.5 hover:shadow-md"
        data-index="2"
        style="display:none;">
        {{ section.settings.cta_label_3 | default: 'SHOP NOW' }}
        {% if section.settings.show_price and section.settings.price_3 != blank %}
          <span class="font-normal normal-case tracking-normal">– {{ section.settings.price_3 }}</span>
        {% endif %}
      </a>
    </div>

  </div>

</section>

<style>
  .hero-image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    transition: opacity 0.6s ease-in-out;
  }

  .hero-image.active {
    opacity: 1 !important;
  }

  .nav-btn.active {
    color: #ffffff !important;
  }

  .nav-btn.active .nav-indicator {
    background: #ffffff !important;
    border-color: #ffffff !important;
  }
</style>

<script>
  (function() {
    const navButtons = document.querySelectorAll('.nav-btn');
    const heroImages = document.querySelectorAll('.hero-image');
    const contentSets = document.querySelectorAll('.content-set');
    const ctaButtons = document.querySelectorAll('.cta-btn');
    const testimonialCards = document.querySelectorAll('.testimonial-card');
    
    navButtons.forEach(button => {
      button.addEventListener('click', function() {
        const index = parseInt(this.getAttribute('data-index'));
        
        // Remove active class from all buttons
        navButtons.forEach(btn => btn.classList.remove('active'));
        
        // Add active class to clicked button
        this.classList.add('active');
        
        // Hide all images
        heroImages.forEach(img => {
          img.classList.remove('active');
          img.style.opacity = '0';
        });
        
        // Show selected image
        const targetImage = document.querySelector(`.hero-image[data-index="${index}"]`);
        if (targetImage) {
          targetImage.classList.add('active');
          targetImage.style.opacity = '1';
        }
        
        // Hide all content sets
        contentSets.forEach(content => {
          content.classList.remove('active');
          content.style.display = 'none';
        });
        
        // Show selected content
        const targetContent = document.querySelector(`.content-set[data-index="${index}"]`);
        if (targetContent) {
          targetContent.classList.add('active');
          targetContent.style.display = 'block';
        }
        
        // Hide all CTA buttons
        ctaButtons.forEach(cta => {
          cta.classList.remove('active');
          cta.style.display = 'none';
        });
        
        // Show selected CTA
        const targetCTA = document.querySelector(`.cta-btn[data-index="${index}"]`);
        if (targetCTA) {
          targetCTA.classList.add('active');
          targetCTA.style.display = 'inline-flex';
        }
        
        // Hide all testimonial cards
        testimonialCards.forEach(card => {
          card.classList.remove('active');
          card.classList.add('hidden');
        });
        
        // Show selected testimonial card
        const targetCard = document.querySelector(`.testimonial-card[data-index="${index}"]`);
        if (targetCard) {
          targetCard.classList.add('active');
          targetCard.classList.remove('hidden');
        }
      });
    });
  })();
</script>

