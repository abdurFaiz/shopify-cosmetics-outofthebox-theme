<section
  style="background-color: {{ section.settings.background_color }};"
  class="about-section-{{ section.id }} full-width w-full overflow-hidden"
>
  <div class="grid grid-cols-1 md:grid-cols-2 min-h-[560px]">
    <!-- Left Column -->
    <div class="flex flex-col gap-10 justify-center px-6 py-12 md:px-10 md:py-14 lg:px-14 bg-inherit order-2 md:order-1">
      <!-- Heading -->
      {% if section.settings.heading != blank %}
        <h2 class="font-serif text-[26px] md:text-[34px] font-normal leading-[1.2] tracking-[-0.01em] text-[#2a2a2a] mb-7 md:mb-10 text-center">
          {{ section.settings.heading }}
        </h2>
      {% endif %}

      <!-- Two small gallery images -->
      <div class="flex gap-6 mb-7 md:mb-10 justify-center">
        <figure class="m-0 overflow-hidden aspect-[3/4] max-w-[130px] md:max-w-[220px] flex-1">
          {% if section.settings.gallery_image_1 %}
            {{
              section.settings.gallery_image_1
              | image_url: width: 400
              | image_tag: loading: 'lazy', widths: '200, 400', class: 'w-full h-full object-cover object-center block'
            }}
          {% else %}
            {{
              images['about_2.jpg']
              | image_url: width: 400
              | image_tag:
                loading: 'lazy',
                widths: '200, 400',
                class: 'w-full h-full object-cover object-center block',
                alt: 'Gallery image 1'
            }}
          {% endif %}
        </figure>
        <figure class="m-0 overflow-hidden aspect-[3/4] max-w-[130px] md:max-w-[220px] flex-1">
          {% if section.settings.gallery_image_2 %}
            {{
              section.settings.gallery_image_2
              | image_url: width: 400
              | image_tag: loading: 'lazy', widths: '200, 400', class: 'w-full h-full object-cover object-center block'
            }}
          {% else %}
            {{
              images['about_3.jpg']
              | image_url: width: 400
              | image_tag:
                loading: 'lazy',
                widths: '200, 400',
                class: 'w-full h-full object-cover object-center block',
                alt: 'Gallery image 2'
            }}
          {% endif %}
        </figure>
      </div>

      <!-- Body text -->
      {% if section.settings.body_text != blank %}
        <p class="font-sans text-[13px] md:text-[14px] font-normal leading-[1.75] text-[#2a2a2a] text-center mb-8 max-w-[360px] self-center">
          {{ section.settings.body_text }}
        </p>
      {% endif %}

      <!-- CTA link -->
      {% if section.settings.cta_label != blank and section.settings.cta_url != blank %}
        <a
          href="{{ section.settings.cta_url }}"
          class="font-sans text-[12px] font-normal tracking-[0.1em] uppercase underline underline-offset-[3px] text-[#2a2a2a] self-center transition-opacity duration-200 hover:opacity-60"
        >
          {{ section.settings.cta_label }}
        </a>
      {% endif %}
    </div>

    <!-- Right Column — full-bleed portrait image -->
    <div class="relative overflow-hidden min-h-[420px] md:min-h-[800px] order-1 md:order-2">
      {% if section.settings.hero_image %}
        {{
          section.settings.hero_image
          | image_url: width: 1440
          | image_tag:
            loading: 'lazy',
            widths: '600, 900, 1200',
            class: 'absolute inset-0 w-full h-full object-cover object-top block'
        }}
      {% else %}
        {{
          images['about_1.jpg']
          | image_url: width: 1440
          | image_tag:
            loading: 'lazy',
            widths: '600, 900, 1200',
            class: 'absolute inset-0 w-full h-full object-cover object-top block',
            alt: 'About hero image'
        }}
      {% endif %}
    </div>
  </div>
</section>

<script>
  (function () {
    'use strict';

    if (typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') return;

    gsap.registerPlugin(ScrollTrigger);

    const section = document.querySelector('.about-section-{{ section.id }}');
    if (!section) return;

    const mm = gsap.matchMedia();

    mm.add(
      {
        isDesktop: '(min-width: 1024px)',
        isTablet: '(min-width: 768px) and (max-width: 1023px)',
        isMobile: '(max-width: 767px)',
        reduceMotion: '(prefers-reduced-motion: reduce)',
      },
      (context) => {
        const { isDesktop, isTablet, isMobile, reduceMotion } = context.conditions;

        const yDistance = isMobile ? 20 : isTablet ? 25 : 30;
        const duration = reduceMotion ? 0 : isMobile ? 0.6 : 0.8;
        const staggerDelay = reduceMotion ? 0 : isMobile ? 0.1 : 0.2;

        // Fade in heading
        const heading = section.querySelector('h2');
        if (heading) {
          gsap.from(heading, {
            opacity: reduceMotion ? 1 : 0,
            y: reduceMotion ? 0 : yDistance,
            duration: duration,
            ease: 'power2.out',
            scrollTrigger: {
              trigger: heading,
              start: isMobile ? 'top 85%' : 'top 80%',
              toggleActions: 'play none none none',
            },
          });
        }

        // Stagger gallery images
        const figures = section.querySelectorAll('figure');
        if (figures.length > 0) {
          gsap.from(figures, {
            opacity: reduceMotion ? 1 : 0,
            y: reduceMotion ? 0 : isMobile ? 30 : 40,
            duration: duration,
            stagger: staggerDelay,
            ease: 'power2.out',
            scrollTrigger: {
              trigger: section.querySelector('.flex.gap-6'),
              start: isMobile ? 'top 80%' : 'top 75%',
              toggleActions: 'play none none none',
            },
          });
        }

        // Fade in body text
        const bodyText = section.querySelector('p');
        if (bodyText) {
          gsap.from(bodyText, {
            opacity: reduceMotion ? 1 : 0,
            y: reduceMotion ? 0 : isMobile ? 15 : 20,
            duration: duration,
            ease: 'power2.out',
            scrollTrigger: {
              trigger: bodyText,
              start: isMobile ? 'top 85%' : 'top 80%',
              toggleActions: 'play none none none',
            },
          });
        }

        // Parallax effect on hero image (disabled on mobile and reduced motion)
        const heroImg = section.querySelector('.order-1 img');
        if (heroImg && !isMobile && !reduceMotion) {
          gsap.to(heroImg, {
            y: isTablet ? -30 : -50,
            ease: 'none',
            scrollTrigger: {
              trigger: section,
              start: 'top bottom',
              end: 'bottom top',
              scrub: 1,
            },
          });
        }

        // CTA link animation
        const ctaLink = section.querySelector('a');
        if (ctaLink) {
          gsap.from(ctaLink, {
            opacity: reduceMotion ? 1 : 0,
            y: reduceMotion ? 0 : 15,
            duration: duration,
            ease: 'power2.out',
            scrollTrigger: {
              trigger: ctaLink,
              start: isMobile ? 'top 90%' : 'top 85%',
              toggleActions: 'play none none none',
            },
          });
        }
      }
    );
  })();
</script>

{% schema %}
{
  "name": "About Section",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "Born from ritual. </br> Perfected by science."
    },
    {
      "type": "header",
      "content": "Gallery Images"
    },
    {
      "type": "image_picker",
      "id": "gallery_image_1",
      "label": "Gallery Image 1",
      "info": "Small portrait image — e.g. a key ingredient or texture close-up"
    },
    {
      "type": "image_picker",
      "id": "gallery_image_2",
      "label": "Gallery Image 2",
      "info": "Small portrait image — e.g. product flatlay or ritual moment"
    },
    {
      "type": "header",
      "content": "Body Content"
    },
    {
      "type": "textarea",
      "id": "body_text",
      "label": "Body Text",
      "default": "We believe beauty is a ritual, not a routine. Every formula we craft starts with skin science and ends with sensory pleasure clean actives, luxurious textures, and ingredients chosen for what they do, not just how they look. Because your skin deserves both results and the experience of getting there."
    },
    {
      "type": "header",
      "content": "Call to Action"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA Label",
      "default": "DISCOVER OUR STORY"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA URL"
    },
    {
      "type": "header",
      "content": "Hero Image"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero Image (Right Column)",
      "info": "Tall portrait photo — model, product, or beauty ritual shot"
    }
  ],
  "presets": [
    {
      "name": "About Section",
      "category": "About"
    }
  ]
}
{% endschema %}
