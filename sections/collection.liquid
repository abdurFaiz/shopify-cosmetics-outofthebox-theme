<section class="collection-section-{{ section.id }} w-full full-width">
  {%- liquid
    assign fetchpriority = 'auto'
    assign loading = 'lazy'
    if section.index == 1
      assign fetchpriority = 'high'
      assign loading = 'eager'
    endif
  -%}

  {%- comment -%} ── Split-panel hero ── {%- endcomment -%}
  <div class="flex flex-col md:flex-row w-full min-h-[70vh] md:min-h-screen md:h-screen">
    {%- comment -%} ── Left panel ── {%- endcomment -%}
    <div class="collection-panel collection-panel--left relative flex-1 overflow-hidden min-h-[50vh] md:h-full flex flex-col">
      {%- comment -%} Background image {%- endcomment -%}
      <div class="absolute inset-0 z-0">
        {% if section.settings.left_image %}
          {{
            section.settings.left_image
            | image_url: width: 1200
            | image_tag:
              loading: loading,
              fetchpriority: fetchpriority,
              widths: '600, 900, 1200',
              class: 'w-full h-full object-cover object-center',
              style: 'width: 100%; height: 100%;',
              alt: section.settings.left_image.alt
            | default: section.settings.left_heading
            | escape
          }}
        {% else %}
          {{
            images['hero-image-2.jpg']
            | image_url: width: 1200
            | image_tag:
              alt: section.settings.left_heading,
              class: 'w-full h-full object-cover object-center',
              style: 'width: 100%; height: 100%;',
              loading: loading,
              fetchpriority: fetchpriority,
              widths: '600, 900, 1200'
          }}
        {% endif %}
      </div>

      {%- comment -%} Dark overlay for text legibility {%- endcomment -%}
      <div class="absolute inset-0 z-1 bg-linear-to-t from-black/50 to-transparent pointer-events-none"></div>

      {%- comment -%} Content {%- endcomment -%}
      <div class="relative z-2 flex flex-col justify-end h-full min-h-[50vh] p-4 sm:p-6 md:p-8">
        {%- comment -%} Top: heading + subtitle {%- endcomment -%}
        <div class="flex flex-col gap-2 sm:gap-3 pb-6 sm:pb-8 max-w-xs sm:max-w-sm md:max-w-md">
          {% if section.settings.left_heading != blank %}
            <h2 class="collection-panel__heading m-0 text-white font-serif font-normal leading-none text-3xl sm:text-4xl md:text-5xl lg:text-6xl">
              {{ section.settings.left_heading }}
            </h2>
          {% endif %}
          {% if section.settings.left_subtitle != blank %}
            <p class="collection-panel__subtitle m-0 text-white font-sans text-[10px] sm:text-xs md:text-sm font-medium uppercase tracking-wider sm:tracking-widest leading-snug">
              {{ section.settings.left_subtitle }}
            </p>
          {% endif %}
        </div>

        {%- comment -%} Bottom: CTA button {%- endcomment -%}
        {% if section.settings.left_cta_label != blank %}
          <a
            href="{{ section.settings.left_cta_url }}"
            class="flex items-center justify-between w-full px-4 sm:px-5 py-3 sm:py-4 md:py-5 font-sans text-xs sm:text-sm md:text-base font-semibold uppercase tracking-wide sm:tracking-widest no-underline transition-opacity duration-300 hover:opacity-90"
            style="background-color: {{ section.settings.left_cta_color }}; color: {{ section.settings.left_cta_text_color }};"
          >
            <span class="text-base sm:text-lg md:text-xl" aria-hidden="true">+</span>
            <span class="flex-1 text-center">{{ section.settings.left_cta_label }}</span>
            <span class="text-base sm:text-lg md:text-xl" aria-hidden="true">+</span>
          </a>
        {% endif %}
      </div>
    </div>

    {%- comment -%} ── Right panel ── {%- endcomment -%}
    <div class="collection-panel collection-panel--right relative flex-1 overflow-hidden min-h-[50vh] md:h-full flex flex-col">
      {%- comment -%} Background image {%- endcomment -%}
      <div class="absolute inset-0 z-0">
        {% if section.settings.right_image %}
          {{
            section.settings.right_image
            | image_url: width: 1200
            | image_tag:
              loading: loading,
              fetchpriority: fetchpriority,
              widths: '600, 900, 1200',
              class: 'w-full h-full object-cover object-center',
              style: 'width: 100%; height: 100%;',
              alt: section.settings.right_image.alt
            | default: section.settings.right_heading
            | escape
          }}
        {% else %}
          {{
            images['hero-image-3.jpg']
            | image_url: width: 1200
            | image_tag:
              alt: section.settings.right_heading,
              class: 'w-full h-full object-cover object-center',
              style: 'width: 100%; height: 100%;',
              loading: loading,
              fetchpriority: fetchpriority,
              widths: '600, 900, 1200'
          }}
        {% endif %}
      </div>

      {%- comment -%} Dark overlay for text legibility {%- endcomment -%}
      <div class="absolute inset-0 z-1 bg-linear-to-t from-black/50 to-transparent  pointer-events-none"></div>

      {%- comment -%} Content {%- endcomment -%}
      <div class="relative z-2 flex flex-col justify-end h-full p-4 sm:p-6 md:p-8">
        {%- comment -%} Top: heading + subtitle {%- endcomment -%}
        <div class="flex flex-col pb-6 sm:pb-8 gap-2 sm:gap-3 max-w-xs sm:max-w-sm md:max-w-md">
          {% if section.settings.right_heading != blank %}
            <h2 class="collection-panel__heading m-0 text-white font-serif font-normal leading-none text-3xl sm:text-4xl md:text-5xl lg:text-6xl">
              {{ section.settings.right_heading }}
            </h2>
          {% endif %}
          {% if section.settings.right_subtitle != blank %}
            <p class="collection-panel__subtitle m-0 text-white font-sans text-[10px] sm:text-xs md:text-sm font-medium uppercase tracking-wider sm:tracking-widest leading-snug">
              {{ section.settings.right_subtitle }}
            </p>
          {% endif %}
        </div>

        {%- comment -%} Bottom: CTA button {%- endcomment -%}
        {% if section.settings.right_cta_label != blank %}
          <a
            href="{{ section.settings.right_cta_url | default: '#' }}"
            class="flex items-center justify-between w-full px-4 sm:px-5 py-3 sm:py-4 md:py-5 font-sans text-xs sm:text-sm md:text-base font-semibold uppercase tracking-wide sm:tracking-widest no-underline transition-opacity duration-300 hover:opacity-90"
            style="background-color: {{ section.settings.right_cta_color }}; color: {{ section.settings.right_cta_text_color }};"
          >
            <span class="text-base sm:text-lg md:text-xl" aria-hidden="true">+</span>
            <span class="flex-1 text-center">{{ section.settings.right_cta_label }}</span>
            <span class="text-base sm:text-lg md:text-xl" aria-hidden="true">+</span>
          </a>
        {% endif %}
      </div>
    </div>
  </div>

  {%- comment -%} ── Product grid ── {%- endcomment -%}
  {% if section.settings.show_products %}
    <div class="collection-products w-full flex flex-col justify-center items-center px-4 sm:px-6 md:px-8 lg:px-12 py-8 sm:py-12 md:py-16 bg-white">
      <h1 class="collection-products__title font-serif font-normal text-2xl sm:text-3xl md:text-4xl lg:text-5xl text-[#241EC6] text-center pb-6 sm:pb-8">
        The Collection of ECHMA
      </h1>

      {% paginate collection.products by 20 %}
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3 sm:gap-4 md:gap-6 justify-center items-center w-full max-w-7xl">
          {% for product in collection.products %}
            <div class="collection-product bg-white rounded-xs overflow-hidden shadow-sm hover:shadow-md transition-shadow duration-300 w-full">
              {%- comment -%} Image container with add-to-cart button {%- endcomment -%}
              <div class="relative aspect-3/4 bg-gray-100 overflow-hidden w-full">
                <a
                  href="{{ product.url }}"
                  class="block w-full h-full"
                  aria-label="{{ product.title | escape }}"
                >
                  {% if product.featured_image %}
                    {{
                      product.featured_image
                      | image_url: width: 800
                      | image_tag:
                        loading: 'lazy',
                        widths: '400, 600, 800',
                        class: 'w-full h-full object-cover group-hover:scale-105 transition-transform duration-500',
                        alt: product.featured_image.alt
                      | default: product.title
                      | escape
                    }}
                  {% else %}
                    <div class="w-full h-full bg-gray-200 flex items-center justify-center">
                      <span class="text-gray-400 text-sm">No image</span>
                    </div>
                  {% endif %}
                </a>

                {%- comment -%} Category badge — top left {%- endcomment -%}
                {% if product.type != blank %}
                  <div class="absolute top-2 left-2 sm:top-4 sm:left-4 flex items-center gap-2 sm:gap-3">
                    <div
                      class="w-3 h-3 sm:w-4 sm:h-4 shrink-0"
                      style="background-color: {{ section.settings.accent_color }};"
                    ></div>
                    <span
                      class="text-sm sm:text-base md:text-lg lg:text-xl font-normal tracking-wide"
                      style="color: {{ section.settings.accent_color }};"
                    >
                      {{ product.type }}
                    </span>
                  </div>
                {% endif %}

                {%- comment -%} Add to cart button — bottom right {%- endcomment -%}
                <div class="absolute bottom-2 right-2 sm:bottom-4 sm:right-4">
                  <button
                    type="button"
                    onclick="window.location.href='{{ product.url }}'"
                    class="group/btn w-10 h-10 sm:w-12 sm:h-12 cursor-pointer rounded-xs bg-white flex items-center justify-center hover:bg-[#241EC6] transition-colors duration-200"
                    aria-label="Add {{ product.title | escape }} to cart"
                    data-product-id="{{ product.variants.first.id }}"
                  >
                    <span class="w-4 h-4 sm:w-5 sm:h-5 text-gray-900 group-hover/btn:text-white transition-colors duration-200">
                      {%- render 'icon-cart' -%}
                    </span>
                  </button>
                </div>
              </div>

              {%- comment -%} Product info {%- endcomment -%}
              <div class="p-3 sm:p-4 md:p-5 flex flex-col gap-2 sm:gap-3">
                <div class="flex flex-col">
                  <h3 class="text-base sm:text-lg md:text-xl font-normal text-gray-900 mb-1 sm:mb-2 leading-tight">
                    <a href="{{ product.url }}" class="no-underline text-gray-900 hover:underline">
                      {{ product.title | escape }}
                    </a>
                  </h3>
                  {% if product.description != blank %}
                    <p class="text-xs sm:text-sm text-gray-500 mb-2 sm:mb-3 leading-relaxed">
                      {{ product.description | strip_html | truncate: 80 }}
                    </p>
                  {% endif %}
                </div>

                <div class="flex flex-row justify-between items-center">
                  {%- comment -%} Rating stars placeholder {%- endcomment -%}
                  {% if section.settings.show_rating %}
                    <div class="flex items-center gap-1 sm:gap-2">
                      <div class="flex items-center gap-0.5">
                        {% for i in (1..5) %}
                          <svg
                            class="w-3 h-3 sm:w-4 sm:h-4"
                            style="fill: {{ section.settings.accent_color }};"
                            viewBox="0 0 20 20"
                            xmlns="http://www.w3.org/2000/svg"
                          >
                            <path d="M10 15l-5.878 3.09 1.123-6.545L.489 6.91l6.572-.955L10 0l2.939 5.955 6.572.955-4.756 4.635 1.123 6.545z" />
                          </svg>
                        {% endfor %}
                      </div>
                    </div>
                  {% endif %}

                  {%- comment -%} Price {%- endcomment -%}
                  <div class="text-lg sm:text-xl font-medium text-gray-900">
                    {{ product.price | money_without_trailing_zeros }}
                  </div>
                </div>
              </div>
            </div>
          {% endfor %}
        </div>

        {%- comment -%} Pagination {%- endcomment -%}
        <div class="mt-12 flex justify-center">
          {{ paginate | default_pagination }}
        </div>
      {% endpaginate %}
    </div>
  {% endif %}
</section>

<script>
  (function () {
    'use strict';

    if (typeof gsap === 'undefined') return;

    const section = document.querySelector('.collection-section-{{ section.id }}');
    if (!section) return;

    const mm = gsap.matchMedia();

    mm.add(
      {
        isDesktop: '(min-width: 1024px)',
        isTablet: '(min-width: 768px) and (max-width: 1023px)',
        isMobile: '(max-width: 767px)',
        reduceMotion: '(prefers-reduced-motion: reduce)',
      },
      (context) => {
        const { isMobile, reduceMotion } = context.conditions;

        const dur = reduceMotion ? 0 : 0.9;
        const stagger = reduceMotion ? 0 : 0.12;

        // Register ScrollTrigger plugin
        if (typeof ScrollTrigger !== 'undefined') {
          gsap.registerPlugin(ScrollTrigger);
        }

        // Animate panel headings in from top with scroll trigger
        const headings = section.querySelectorAll('.collection-panel__heading');
        if (headings.length) {
          gsap.from(headings, {
            opacity: reduceMotion ? 1 : 0,
            y: reduceMotion ? 0 : isMobile ? -20 : -30,
            duration: dur,
            stagger: stagger,
            ease: 'power2.out',
            scrollTrigger: {
              trigger: section.querySelector('.collection-panel--left'),
              start: 'top 80%',
              toggleActions: 'play none none none',
            },
          });
        }

        // Animate subtitles in with scroll trigger
        const subtitles = section.querySelectorAll('.collection-panel__subtitle');
        if (subtitles.length) {
          gsap.from(subtitles, {
            opacity: reduceMotion ? 1 : 0,
            y: reduceMotion ? 0 : 15,
            duration: reduceMotion ? 0 : 0.7,
            stagger: stagger,
            delay: reduceMotion ? 0 : 0.2,
            ease: 'power2.out',
            scrollTrigger: {
              trigger: section.querySelector('.collection-panel--left'),
              start: 'top 80%',
              toggleActions: 'play none none none',
            },
          });
        }

        // Animate CTA buttons up from bottom with scroll trigger
        const leftCta = section.querySelector('.collection-panel--left a[class*="flex items-center"]');
        const rightCta = section.querySelector('.collection-panel--right a[class*="flex items-center"]');

        if (leftCta) {
          gsap.from(leftCta, {
            opacity: reduceMotion ? 1 : 0,
            y: reduceMotion ? 0 : 30,
            duration: reduceMotion ? 0 : 0.8,
            delay: reduceMotion ? 0 : 0.35,
            ease: 'power2.out',
            scrollTrigger: {
              trigger: section.querySelector('.collection-panel--left'),
              start: 'top 80%',
              toggleActions: 'play none none none',
            },
          });
        }

        if (rightCta) {
          gsap.from(rightCta, {
            opacity: reduceMotion ? 1 : 0,
            y: reduceMotion ? 0 : 30,
            duration: reduceMotion ? 0 : 0.8,
            delay: reduceMotion ? 0 : 0.4,
            ease: 'power2.out',
            scrollTrigger: {
              trigger: section.querySelector('.collection-panel--right'),
              start: 'top 80%',
              toggleActions: 'play none none none',
            },
          });
        }

        // Stagger product cards with scroll trigger
        if (typeof ScrollTrigger !== 'undefined') {
          const cards = section.querySelectorAll('.collection-product');
          if (cards.length) {
            gsap.from(cards, {
              opacity: reduceMotion ? 1 : 0,
              y: reduceMotion ? 0 : isMobile ? 30 : 50,
              duration: reduceMotion ? 0 : 0.7,
              stagger: reduceMotion ? 0 : 0.08,
              ease: 'power2.out',
              scrollTrigger: {
                trigger: section.querySelector('.collection-products'),
                start: isMobile ? 'top 85%' : 'top 75%',
                toggleActions: 'play none none none',
              },
            });
          }

          // Animate collection title with scroll trigger
          const collectionTitle = section.querySelector('.collection-products__title');
          if (collectionTitle) {
            gsap.from(collectionTitle, {
              opacity: reduceMotion ? 1 : 0,
              y: reduceMotion ? 0 : 30,
              duration: reduceMotion ? 0 : 0.8,
              ease: 'power2.out',
              scrollTrigger: {
                trigger: section.querySelector('.collection-products'),
                start: isMobile ? 'top 90%' : 'top 80%',
                toggleActions: 'play none none none',
              },
            });
          }
        }
      }
    );
  })();
</script>

{% schema %}
{
  "name": "Collection — Split Hero",
  "settings": [
    {
      "type": "header",
      "content": "Left Panel"
    },
    {
      "type": "image_picker",
      "id": "left_image",
      "label": "Left Background Image"
    },
    {
      "type": "text",
      "id": "left_heading",
      "label": "Left Heading",
      "default": "Renewal Cream"
    },
    {
      "type": "textarea",
      "id": "left_subtitle",
      "label": "Left Subtitle",
      "default": "Illuminating treatment for radiant skin."
    },
    {
      "type": "text",
      "id": "left_cta_label",
      "label": "Left CTA Label",
      "default": "Limited Renewal Cream"
    },
    {
      "type": "url",
      "id": "left_cta_url",
      "label": "products/renewal-cream"
    },
    {
      "type": "color",
      "id": "left_cta_color",
      "label": "Left CTA Background Color",
      "default": "#e85d26"
    },
    {
      "type": "color",
      "id": "left_cta_text_color",
      "label": "Left CTA Text Color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Right Panel"
    },
    {
      "type": "image_picker",
      "id": "right_image",
      "label": "Right Background Image"
    },
    {
      "type": "text",
      "id": "right_heading",
      "label": "Right Heading",
      "default": "Supercharge Glow Inside"
    },
    {
      "type": "textarea",
      "id": "right_subtitle",
      "label": "Right Subtitle",
      "default": "Lightweight, fast-absorbing hydration boost."
    },
    {
      "type": "text",
      "id": "right_cta_label",
      "label": "Right CTA Label",
      "default": "Shop Bundles"
    },
    {
      "type": "url",
      "id": "right_cta_url",
      "label": "products/superchage-glow-inside"
    },
    {
      "type": "color",
      "id": "right_cta_color",
      "label": "Right CTA Background Color",
      "default": "#1a3a8f"
    },
    {
      "type": "color",
      "id": "right_cta_text_color",
      "label": "Right CTA Text Color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Product Grid"
    },
    {
      "type": "checkbox",
      "id": "show_products",
      "label": "Show Product Grid Below Hero",
      "default": true
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color",
      "default": "#4f46e5",
      "info": "Used for category badge and rating stars"
    },
    {
      "type": "checkbox",
      "id": "show_rating",
      "label": "Show Rating Stars",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Collection — Split Hero",
      "category": "Collection"
    }
  ]
}
{% endschema %}
