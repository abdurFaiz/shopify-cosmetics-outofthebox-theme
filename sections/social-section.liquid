<section id="social-{{ section.id }}" class="relative w-full full-width overflow-hidden bg-white py-16 md:py-20">

  {{- '<!-- Header -->' }}
  <div class="max-w-7xl mx-auto px-6 md:px-10 mb-12">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6">
      <div class="flex flex-col gap-4">
        {% if section.settings.eyebrow != blank %}
          <p class="m-0 font-sans text-xs font-medium text-cosmetics-dark capitalize">
            {{ section.settings.eyebrow }}
          </p>
        {% endif %}
        {% if section.settings.heading != blank %}
          <h2 class="m-0 font-serif font-normal text-[#1a1a1a] leading-tight" style="font-size: clamp(36px, 4vw, 52px);">
            {{ section.settings.heading }}
          </h2>
        {% endif %}
      </div>
      {% if section.settings.cta_text != blank and section.settings.cta_url != blank %}
        <a
          href="{{ section.settings.cta_url }}"
          class="inline-flex items-center gap-2 px-6 py-3 bg-cosmetics-dark text-white font-sans text-sm font-medium tracking-wide uppercase transition-colors hover:bg-black"
          {% if section.settings.cta_new_tab %}
          target="_blank"
          rel="noopener noreferrer"
          {% endif %}>
          {{ section.settings.cta_text }}
          <svg
            width="16"
            height="16"
            viewBox="0 0 16 16"
            fill="none"
            aria-hidden="true">
            <path
              d="M6 3L11 8L6 13"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round" />
          </svg>
        </a>
      {% endif %}
    </div>
    {% if section.settings.body_text != blank %}
      <p class="mt-6 font-sans text-[15px] text-cosmetics-dark leading-relaxed max-w-2xl">
        {{ section.settings.body_text }}
      </p>
    {% endif %}
  </div>

  {{- '<!-- Infinite scrolling track -->' }}
  {% assign social_blocks = section.blocks | where: 'type', 'social_post' %}
  {% if social_blocks.size > 0 %}
    <div class="social-marquee-wrapper relative">
      <div id="social-track-{{ section.id }}" class="social-track flex gap-4 will-change-transform">
        {% for block in social_blocks %}
          <div
            class="social-card shrink-0 relative rounded-lg overflow-hidden bg-[#f5f5f5]"
            style="width: {{ section.settings.card_width }}px; height: {{ section.settings.card_height }}px;"
            {{ block.shopify_attributes }}>

            {{- '<!-- Image/Video layer -->' }}
            <div class="absolute inset-0">
              {% if block.settings.image %}
                {% assign img_alt = block.settings.image.alt | escape %}
                {{ block.settings.image | image_url: width: 600 | image_tag: loading: 'lazy', class: 'w-full h-full object-cover', alt: img_alt }}
              {% elsif block.settings.fallback_image_url != blank %}
                <img
                  src="{{ block.settings.fallback_image_url }}"
                  alt="{{ block.settings.username | escape }}"
                  loading="lazy"
                  class="w-full h-full object-cover">
              {% endif %}
            </div>

            {{- '<!-- Overlay gradient -->' }}
            <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent"></div>

            {{- '<!-- Content overlay -->' }}
            <div class="absolute inset-0 flex flex-col justify-between p-4">
              {{- '<!-- Top: Username -->' }}
              {% if block.settings.username != blank %}
                <div class="flex items-center gap-2">
                  <span class="font-sans text-xs font-semibold text-white uppercase tracking-wider">
                    @{{ block.settings.username }}</span>
                </div>
              {% endif %}

              {{- '<!-- Bottom: Caption -->' }}
              {% if block.settings.caption != blank %}
                <p class="font-sans text-sm text-white leading-relaxed line-clamp-3">
                  {{ block.settings.caption }}
                </p>
              {% endif %}
            </div>

            {{- '<!-- Hover overlay -->' }}
            <div class="absolute inset-0 bg-black/0 transition-colors duration-300 hover:bg-black/20"></div>
          </div>
        {% endfor %}
      </div>
    </div>
  {% endif %}

</section>

<style>
  #social-{{ section.id }} .social-marquee-wrapper {
    overflow: hidden;
  }

  #social-{{ section.id }}
  .social-track {
    display: flex;
  }

  #social-{{ section.id }}
  .social-card {
    user-select: none;
  }
</style>

<script src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/gsap.min.js"></script>
<script>
  (function() {
    'use strict';
  
    const sectionId = '{{ section.id }}';
    const track = document.getElementById('social-track-' + sectionId);
    
    if (!track) return;
  
    const cards = Array.from(track.querySelectorAll('.social-card'));
    const totalCards = cards.length;
    
    if (totalCards === 0) return;
  
    // Clone cards for seamless loop
    const cloneCount = Math.max(3, Math.ceil(window.innerWidth / cards[0].offsetWidth) + 2);
    
    for (let i = 0; i < cloneCount; i++) {
      cards.forEach(card => {
        const clone = card.cloneNode(true);
        clone.setAttribute('aria-hidden', 'true');
        track.appendChild(clone);
      });
    }
  
    // Calculate total width
    function getTotalWidth() {
      const allCards = track.querySelectorAll('.social-card');
      let width = 0;
      allCards.forEach(card => {
        width += card.offsetWidth + 16; // 16px gap
      });
      return width;
    }
  
    const totalWidth = getTotalWidth();
    const duration = {{ section.settings.scroll_duration | default: 30 }};
  
    // Create seamless loop animation
    gsap.set(track, { x: 0 });
    
    const animation = gsap.to(track, {
      x: -totalWidth / 2,
      duration: duration,
      ease: 'none',
      repeat: -1,
      modifiers: {
        x: gsap.utils.wrap(-totalWidth / 2, 0)
      }
    });
  
    // Pause on hover (desktop only)
    if (window.matchMedia('(hover: hover)').matches) {
      track.addEventListener('mouseenter', () => {
        gsap.to(animation, { timeScale: 0, duration: 0.5, ease: 'power2.out' });
      });
      
      track.addEventListener('mouseleave', () => {
        gsap.to(animation, { timeScale: 1, duration: 0.5, ease: 'power2.in' });
      });
    }
  
    // Recalculate on resize
    let resizeTimer;
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(() => {
        animation.kill();
        location.reload(); // Simple approach for resize
      }, 300);
    });
  
  })();
</script>

{% schema %}
  {
    "name": "Social Feed",
    "settings": [
      {
        "type": "header",
        "content": "Section Settings"
      },
      {
        "type": "text",
        "id": "eyebrow",
        "label": "Eyebrow Text",
        "default": "FOLLOW US"
      },
      {
        "type": "text",
        "id": "heading",
        "label": "Heading",
        "default": "Join us in taking skincare beyond the bathroom"
      },
      {
        "type": "textarea",
        "id": "body_text",
        "label": "Body Text",
        "default": "Tag us in your caption, @topicals, to join in on the fun"
      }, {
        "type": "header",
        "content": "Call to Action"
      }, {
        "type": "text",
        "id": "cta_text",
        "label": "Button Text",
        "default": "Tag In"
      }, {
        "type": "url",
        "id": "cta_url",
        "label": "Button URL"
      }, {
        "type": "checkbox",
        "id": "cta_new_tab",
        "label": "Open in new tab",
        "default": true
      }, {
        "type": "header",
        "content": "Card Settings"
      }, {
        "type": "range",
        "id": "card_width",
        "label": "Card Width (px)",
        "min": 200,
        "max": 400,
        "step": 10,
        "default": 280,
        "unit": "px"
      }, {
        "type": "range",
        "id": "card_height",
        "label": "Card Height (px)",
        "min": 300,
        "max": 600,
        "step": 10,
        "default": 400,
        "unit": "px"
      }, {
        "type": "range",
        "id": "scroll_duration",
        "label": "Scroll Duration (seconds)",
        "min": 10,
        "max": 60,
        "step": 5,
        "default": 30,
        "info": "Lower = faster scroll"
      }
    ],
    "blocks": [
      {
        "type": "social_post",
        "name": "Social Post",
        "settings": [
          {
            "type": "image_picker",
            "id": "image",
            "label": "Post Image"
          }, {
            "type": "text",
            "id": "fallback_image_url",
            "label": "Fallback Image URL",
            "info": "Used when no image is picked above"
          }, {
            "type": "text",
            "id": "username",
            "label": "Username (without @)",
            "default": "username"
          }, {
            "type": "textarea",
            "id": "caption",
            "label": "Caption",
            "default": "Free Headband"
          }
        ]
      }
    ],
    "presets": [
      {
        "name": "Social Feed",
        "category": "Social",
        "blocks": [
          {
            "type": "social_post",
            "settings": {
              "username": "polonaamy",
              "caption": "Free Headband"
            }
          }, {
            "type": "social_post",
            "settings": {
              "username": "alexislconway",
              "caption": "🧴✨ for the crib and one for the gym bag"
            }
          }, {
            "type": "social_post",
            "settings": {
              "username": "username3",
              "caption": "My daily routine"
            }
          }, {
            "type": "social_post",
            "settings": {
              "username": "username4",
              "caption": "Glowing skin starts here"
            }
          }
        ]
      }
    ]
  }
{% endschema %}