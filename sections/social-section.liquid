        "label": "Heading",
        "default": "Use it, feel it, and share it with"
      },
      {
        "type": "text",
        "id": "heading-echma",
        "label": "Heading",
        "default": "@ECHMA"
      }, {
        "type": "textarea",
        "id": "body_text",
        "label": "Body Text",
        "default": "Skincare should fit your life, not just your shelf. Come be part of that."
      }, {
        "type": "header",
        "content": "Call to Action"
      }, {
        "type": "text",
        "id": "cta_text",
        "label": "Button Text",
        "default": "Tag Us"
      }, {
        "type": "url",
        "id": "cta_url",
        "label": "Button URL"
      }, {
        "type": "checkbox",
        "id": "cta_new_tab",
