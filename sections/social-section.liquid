              }, {
                "value": "9:16",
                "label": "9:16 (Tall)"
              }
            ],
            "default": "3:4"
          },
          {
            "type": "text",
            "id": "username",
            "label": "Username (without @)",
            "default": "username"
          }, {
            "type": "textarea",
            "id": "caption",
            "label": "Caption",
            "default": "Free Headband"
          }
        ]
      }
    ],
    "presets": [
      {
        "name": "Social Feed",
        "category": "Social",
        "blocks": [
          {
            "type": "social_post",
            "settings": {
              "fallback_image_url": "https://cdn.shopify.com/s/files/1/0814/5217/1522/files/ig_3.jpg?v=1776738649",
