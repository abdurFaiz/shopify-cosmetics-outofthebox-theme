        "default": true
      }, {
        "type": "header",
        "content": "Card Settings"
      }, {
        "type": "range",
        "id": "card_width",
        "label": "Card Width (px)",
        "min": 200,
        "max": 400,
        "step": 10,
        "default": 280,
        "unit": "px"
      }, {
        "type": "range",
        "id": "card_height",
        "label": "Card Height (px)",
        "min": 300,
        "max": 600,
        "step": 10,
        "default": 400,
        "unit": "px"
      }, {
        "type": "range",
        "id": "scroll_duration",
        "label": "Scroll Duration (seconds)",
        "min": 10,
        "max": 60,
        "step": 5,
        "default": 30,
        "info": "Lower = faster scroll"
      }
    ],
    "blocks": [
      {
        "type": "social_post",
        "name": "Social Post",
        "settings": [
          {
            "type": "image_picker",
            "id": "image",
            "label": "Post Image"
          },
          {
            "type": "text",
