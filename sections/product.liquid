          "label": "Product",
          "info": "Select a product to recommend"
        },
        {
          "type": "header",
          "content": "Manual Override (when no product selected)"
        },
        {
          "type": "image_picker",
          "id": "product_image",
          "label": "Product Image"
        },
        {
          "type": "text",
          "id": "product_title",
          "label": "Product Title",
          "default": "Renewal Cream"
        },
        {
          "type": "textarea",
          "id": "product_description",
          "label": "Product Description",
          "default": "Smoothing, strengthening daily moisturizer"
        },
        {
          "type": "text",
          "id": "product_price",
          "label": "Price",
          "default": "$75.00"
        }
      ]
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
