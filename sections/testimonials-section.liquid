<section id="community-{{ section.id }}" class="full-width relative w-full overflow-hidden bg-white">

  <div class="flex flex-col md:flex-row w-full min-h-[780px] px-10 py-16 gap-10 box-border max-w-full mx-auto md:py-20">

    {{- '<!-- LEFT COLUMN: eyebrow, heading, body, controls -->' }}
    <div class="flex flex-col justify-between shrink-0 md:w-[320px] w-full">
      {{- '<!-- Top: eyebrow + heading + body -->' }}
      <div class="flex flex-col gap-4">
        {% if section.settings.eyebrow != blank %}
          <p class="m-0 font-sans text-xs font-medium tracking-[0.12em] text-cosmetics-dark">
            {{ section.settings.eyebrow }}
          </p>
        {% endif %}

        {% if section.settings.heading != blank %}
          <h2 class="m-0 font-serif font-normal text-[#1a1a1a] leading-tight" style="font-size: clamp(36px, 4vw, 52px);">
            {{ section.settings.heading }}
          </h2>
        {% endif %}
      </div>

      {{- '<!-- Bottom: body copy + nav controls -->' }}
      <div class="flex flex-col gap-6 mt-10 md:mt-0">
        {% if section.settings.body_text != blank %}
          <p class="m-0 font-sans text-[13px] font-normal text-cosmetics-dark leading-relaxed max-w-[260px]">
            {{ section.settings.body_text }}
          </p>
        {% endif %}

        {{- '<!-- Prev / Next + counter -->' }}
        <div class="flex items-center gap-3">
          <button
            id="community-prev-{{ section.id }}"
            class="community-prev flex items-center justify-center w-10 h-10 border border-cosmetics-dark bg-transparent cursor-pointer transition-colors duration-300 hover:bg-cosmetics-dark hover:text-white group"
            aria-label="{{ section.settings.prev_label | default: 'Previous' }}">
            <svg
              width="14"
              height="14"
              viewBox="0 0 14 14"
              fill="none"
              aria-hidden="true">
              <path
                d="M9 2L4 7L9 12"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round" />
            </svg>
          </button>
          <button
            id="community-next-{{ section.id }}"
            class="community-next flex items-center justify-center w-10 h-10 border border-cosmetics-dark bg-transparent cursor-pointer transition-colors duration-300 hover:bg-cosmetics-dark hover:text-white group"
            aria-label="{{ section.settings.next_label | default: 'Next' }}">
            <svg
              width="14"
              height="14"
              viewBox="0 0 14 14"
              fill="none"
              aria-hidden="true">
              <path
                d="M5 2L10 7L5 12"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round" />
            </svg>
          </button>
          <span
            id="community-counter-{{ section.id }}"
            class="font-sans text-[12px] text-cosmetics-dark tracking-wide ml-1"
            aria-live="polite">
            1 / {{ section.blocks | size }}
          </span>
        </div>
      </div>

    </div>

    {{- '<!-- RIGHT COLUMN: scrollable cards track -->' }}
    {% assign card_blocks = section.blocks | where: 'type', 'card' %}
    {% assign card_count = card_blocks | size %}

    <div class="community-track-wrapper flex-1 overflow-hidden relative">
      <div
        id="community-track-{{ section.id }}"
        class="community-track flex will-change-transform h-full"
        style="gap: {{ section.settings.card_gap }}px; cursor: grab;">

        {% for block in card_blocks %}
          <div class="community-card shrink-0 relative rounded-md overflow-hidden w-[500px] h-full" {{ block.shopify_attributes }}>

            {{- '<!-- Card image + video layers -->' }}
            <div class="absolute inset-0 w-full h-full">
              {% if block.settings.image %}
                {% assign card_img_alt = block.settings.image.alt | escape %}
                {{ block.settings.image | image_url: width: 700 | image_tag: loading: 'lazy', class: 'community-card__img-layer absolute inset-0 w-full h-full object-cover object-center', alt: card_img_alt, width: 700 }}
              {% elsif block.settings.fallback_image_url != blank %}
                <img
                  src="{{ block.settings.fallback_image_url }}"
                  alt="{{ block.settings.username | escape }}"
                  loading="lazy"
                  class="community-card__img-layer absolute inset-0 w-full h-full object-cover object-center"
                  width="700">
              {% else %}
              {% endif %}

              {% if block.settings.hover_video_url != blank %}
                <video
                  class="community-card__video-layer absolute inset-0 w-full h-full object-cover object-center"
                  src="{{ block.settings.hover_video_url }}"
                  muted
                  playsinline
                  loop
                  preload="auto"
                  aria-hidden="true"
                  style="opacity:0; transition: opacity 0.5s ease;"></video>
              {% endif %}
            </div>

            {{- '<!-- Top gradient fade -->' }}
            <div class="pointer-events-none absolute inset-x-0 top-0 h-40 bg-gradient-to-b from-black/60 to-transparent z-10"></div>

            {{- '<!-- Top overlay row: username left, play/pause button right -->' }}
            <div class="absolute top-0 left-0 right-0 flex items-center justify-between px-4 pt-4 z-20">
              {% if block.settings.username != blank %}
                <span class="font-sans text-[10px] font-medium text-white uppercase tracking-[0.08em]" style="text-shadow: 0 1px 4px rgba(0,0,0,0.45);">
                  @{{ block.settings.username }}</span>
              {% endif %}
              {% if block.settings.hover_video_url != blank %}
                <button
                  type="button"
                  class="community-card__playbtn ml-auto flex items-center justify-center w-7 h-7 rounded-full bg-white/15 backdrop-blur-[10px] cursor-pointer border-0 p-0 relative z-30"
                  aria-label="Play video"
                  data-playing="false">
                  {{- '<!-- Play icon (default) -->' }}
                  <svg
                    class="community-card__play-icon"
                    width="10"
                    height="10"
                    viewBox="0 0 10 10"
                    fill="white"
                    aria-hidden="true">
                    <path d="M2 1.5L9 5L2 8.5V1.5Z" />
                  </svg>
                  {{- '<!-- Pause icon (hidden by default) -->' }}
                  <svg
                    class="community-card__pause-icon"
                    width="10"
                    height="10"
                    viewBox="0 0 10 10"
                    fill="white"
                    aria-hidden="true"
                    style="display:none;">
                    <rect
                      x="1.5"
                      y="1"
                      width="2.5"
                      height="8"
                      rx="0.5" />
                    <rect
                      x="6"
                      y="1"
                      width="2.5"
                      height="8"
                      rx="0.5" />
                  </svg>
                </button>
              {% else %}
                <div class="flex items-center justify-center w-7 h-7 rounded-full bg-white/15 backdrop-blur-[10px] ml-auto">
                  <svg
                    width="10"
                    height="10"
                    viewBox="0 0 10 10"
                    fill="white"
                    aria-hidden="true">
                    <path d="M2 1.5L9 5L2 8.5V1.5Z" />
                  </svg>
                </div>
              {% endif %}
            </div>

            {{- '<!-- Bottom-left: product pill card -->' }}
            {% assign has_prod_img = false %}
            {% if block.settings.product_image %}
              {% assign has_prod_img = true %}
            {% elsif block.settings.fallback_product_image_url != blank %}
              {% assign has_prod_img = true %}
            {% endif %}
            {% if has_prod_img or block.settings.product_name != blank %}
              <div class="absolute bottom-3 left-3 z-10 flex items-center gap-3 rounded-lg bg-white px-1.5 py-1.5 max-w-[475px] w-full ">
                {{- '<!-- Product image -->' }}
                <div class="shrink-0 size-14 rounded-lg overflow-hidden bg-[#f5f1ed]">
                  {% if block.settings.product_image %}
                    {% assign prod_img_alt = block.settings.product_image.alt | escape %}
                    {{ block.settings.product_image | image_url: width: 120 | image_tag: loading: 'lazy', class: 'w-full h-full object-cover', alt: prod_img_alt }}
                  {% elsif block.settings.fallback_product_image_url != blank %}
                    <img
                      src="{{ block.settings.fallback_product_image_url }}"
                      alt="{{ block.settings.product_name | escape }}"
                      loading="lazy"
                      class="w-full h-full object-cover"
                      width="120">
                  {% endif %}
                </div>
                {{- '<!-- Product name + price -->' }}
                {% if block.settings.product_name != blank or block.settings.product_price != blank %}
                  <div class="flex flex-col gap-2 min-w-0 flex-1">
                    {% if block.settings.product_name != blank %}
                      <span class="font-sans text-sm font-semibold text-[#1a1a1a] leading-tight truncate">{{ block.settings.product_name }}</span>
                    {% endif %}
                    {% if block.settings.product_price != blank %}
                      <span class="font-sans text-xs text-[#555] leading-tight mt-0.5">{{ block.settings.product_price }}</span>
                    {% endif %}
                  </div>
                {% endif %}
                {{- '<!-- Cart icon button -->' }}
                <button
                  type="button"
                  aria-label="Add to cart"
                  class="shrink-0 ml-auto flex items-center justify-center size-14 rounded-md bg-[#f4f4f4]/80 text-white hover:bg-[#f1f1f1] transition-colors">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="size-6 text-black"
                    aria-hidden="true">
                    <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z" />
                    <line
                      x1="3"
                      y1="6"
                      x2="21"
                      y2="6" />
                    <path d="M16 10a4 4 0 0 1-8 0" />
                  </svg>
                </button>
              </div>
            {% endif %}

          </div>
        {% endfor %}

      </div>
    </div>

  </div>

</section>

<style>
  #community-{{ section.id }} .community-track {
    user-select: none;
    -webkit-user-select: none;
  }

  #community-{{ section.id }}
  .community-track.is-dragging {
    cursor: grabbing;
  }

  #community-{{ section.id }}
  .community-card__img {
    transition: transform 0.55s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    will-change: transform;
  }

  @media (hover: hover) {
    #community-{{ section.id }}.community-card:hover .community-card__img {
      transform: scale(1.04);
    }
  }

  /* Hover video layer */
  #community-{{ section.id }} .community-card__img-layer {
    transition: opacity 0.5s ease;
  }

  #community-{{ section.id }}
  .community-card__video-layer {
    transition: opacity 0.5s ease;
  }

  #community-{{ section.id }}
  .community-card.video-active .community-card__img-layer {
    opacity: 0;
  }

  #community-{{ section.id }}
  .community-card.video-active .community-card__video-layer {
    opacity: 1 !important;
  }

  @media (max-width: 768px) {
    #community-{{ section.id }} .community-track-wrapper {
      width: 100%;
    }

    #community-{{ section.id }}
    .community-card {
      width: 340px !important;
    }
  }
</style>

<script>
  (function () {
    'use strict';
  
    var sectionId  = '{{ section.id }}';
    var totalCards = {{ card_blocks | size }};
    var track      = document.getElementById('community-track-' + sectionId);
    var prevBtn    = document.getElementById('community-prev-' + sectionId);
    var nextBtn    = document.getElementById('community-next-' + sectionId);
    var counter    = document.getElementById('community-counter-' + sectionId);
    var GAP        = {{ section.settings.card_gap }};
  
    if (!track || !prevBtn || !nextBtn || totalCards === 0) return;
  
    // ── Clone cards for infinite loop ──────────────────────────────────────
    var originals = Array.from(track.querySelectorAll('.community-card'));
    var total     = originals.length;
  
    var prependArr = originals.slice().reverse().map(function (el) {
      var clone = el.cloneNode(true);
      clone.setAttribute('aria-hidden', 'true');
      return clone;
    }).reverse();
    prependArr.forEach(function (node) { track.insertBefore(node, track.firstChild); });
  
    originals.forEach(function (el) {
      var clone = el.cloneNode(true);
      clone.setAttribute('aria-hidden', 'true');
      track.appendChild(clone);
    });
  
    // ── State ───────────────────────────────────────────────────────────────
    var currentIndex = 0;
    var isDragging   = false;
    var startX       = 0;
    var startTransX  = 0;
    var isAnimating  = false;
  
    function getStep() {
      var cards = track.querySelectorAll('.community-card');
      if (!cards.length) return 0;
      return cards[0].offsetWidth + GAP;
    }
  
    function domIndexOf(logicalIndex) { return total + logicalIndex; }
  
    function getTranslateX() {
      var matrix = new DOMMatrix(window.getComputedStyle(track).transform);
      return matrix.m41;
    }
  
    function setTranslateX(x, animate, onDone) {
      if (typeof gsap !== 'undefined') {
        if (!animate) {
          gsap.set(track, { x: x });
          if (onDone) onDone();
        } else {
          gsap.to(track, { x: x, duration: 0.55, ease: 'power2.out', onComplete: onDone || null });
        }
      } else {
        track.style.transition = animate ? 'transform 0.55s cubic-bezier(0.25,0.46,0.45,0.94)' : 'none';
        track.style.transform  = 'translateX(' + x + 'px)';
        if (onDone) {
          if (animate) {
            track.addEventListener('transitionend', function handler() {
              track.removeEventListener('transitionend', handler);
              onDone();
            });
          } else { onDone(); }
        }
      }
    }
  
    function targetXForIndex(logicalIndex) {
      return -(domIndexOf(logicalIndex) * getStep());
    }
  
    function updateCounter() {
      if (counter) counter.textContent = (currentIndex + 1) + ' / ' + total;
    }
  
    function teleportToIndex(logicalIndex) {
      currentIndex = ((logicalIndex % total) + total) % total;
      setTranslateX(targetXForIndex(currentIndex), false);
      updateCounter();
    }
  
    function slideTo(logicalIndex, animate) {
      if (isAnimating) return;
      isAnimating = true;
      var wrapped   = ((logicalIndex % total) + total) % total;
      var domTarget = total + logicalIndex;
      var targetX   = -(domTarget * getStep());
      setTranslateX(targetX, animate !== false, function () {
        currentIndex = wrapped;
        setTranslateX(targetXForIndex(currentIndex), false);
        isAnimating = false;
        updateCounter();
      });
    }
  
    teleportToIndex(0);
  
    // ── Controls ────────────────────────────────────────────────────────────
    prevBtn.addEventListener('click', function () { slideTo(currentIndex - 1, true); });
    nextBtn.addEventListener('click', function () { slideTo(currentIndex + 1, true); });
    prevBtn.addEventListener('keydown', function (e) {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); slideTo(currentIndex - 1, true); }
    });
    nextBtn.addEventListener('keydown', function (e) {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); slideTo(currentIndex + 1, true); }
    });
  
    // ── Drag / swipe ────────────────────────────────────────────────────────
    function onPointerDown(e) {
      if (isAnimating) return;
      isDragging  = true;
      startX      = e.type === 'touchstart' ? e.touches[0].clientX : e.clientX;
      startTransX = getTranslateX();
      track.classList.add('is-dragging');
      if (typeof gsap !== 'undefined') gsap.killTweensOf(track);
    }
  
    function onPointerMove(e) {
      if (!isDragging) return;
      var clientX = e.type === 'touchmove' ? e.touches[0].clientX : e.clientX;
      setTranslateX(startTransX + (clientX - startX), false);
    }
  
    function onPointerUp(e) {
      if (!isDragging) return;
      isDragging = false;
      track.classList.remove('is-dragging');
      var clientX = e.type === 'touchend'
        ? (e.changedTouches[0] ? e.changedTouches[0].clientX : startX)
        : e.clientX;
      var delta = clientX - startX;
      var step  = getStep();
      if (Math.abs(delta) > step * 0.2) {
        slideTo(delta < 0 ? currentIndex + 1 : currentIndex - 1, true);
      } else {
        isAnimating = true;
        setTranslateX(targetXForIndex(currentIndex), true, function () { isAnimating = false; });
      }
    }
  
    track.addEventListener('mousedown',  onPointerDown);
    track.addEventListener('touchstart', onPointerDown, { passive: true });
    window.addEventListener('mousemove', onPointerMove);
    window.addEventListener('touchmove', onPointerMove, { passive: true });
    window.addEventListener('mouseup',   onPointerUp);
    window.addEventListener('touchend',  onPointerUp);
    track.addEventListener('dragstart',  function (e) { e.preventDefault(); });
  
    // ── Resize ──────────────────────────────────────────────────────────────
    var resizeTimer;
    window.addEventListener('resize', function () {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(function () { teleportToIndex(currentIndex); }, 150);
    });
    function setPlayBtnState(btn, playing) {
      if (!btn) return;
      btn.setAttribute('data-playing', playing ? 'true' : 'false');
      btn.setAttribute('aria-label', playing ? 'Pause video' : 'Play video');
      var playIcon  = btn.querySelector('.community-card__play-icon');
      var pauseIcon = btn.querySelector('.community-card__pause-icon');
      if (playIcon)  playIcon.style.display = playing ? 'none' : 'block';
      if (pauseIcon) pauseIcon.style.display = playing ? 'block' : 'none';
    }
  
    function showVideo(card) {
      var video = card.querySelector('.community-card__video-layer');
      if (!video) {
        console.log('No video found in card');
        return;
      }
      
      console.log('Attempting to play video:', video.src);
      
      var img = card.querySelector('.community-card__img-layer');
      if (img) img.style.opacity = '0';
      video.style.opacity = '1';
      card.classList.add('video-active');
      
      // Load the video if not loaded
      if (video.readyState < 2) {
        video.load();
      }
      
      var playPromise = video.play();
      if (playPromise !== undefined) {
        playPromise.then(function() {
          console.log('Video playing successfully');
          var btn = card.querySelector('.community-card__playbtn');
          if (btn) setPlayBtnState(btn, true);
        }).catch(function (err) { 
          console.error('Video play failed:', err);
          // Try to reload and play again
          video.load();
          setTimeout(function() {
            video.play().catch(function(e) {
              console.error('Second play attempt failed:', e);
            });
          }, 100);
        });
      }
    }
  
    function hideVideo(card) {
      var video = card.querySelector('.community-card__video-layer');
      if (!video) return;
      console.log('Hiding video');
      video.pause();
      video.currentTime = 0;
      video.style.opacity = '0';
      var img = card.querySelector('.community-card__img-layer');
      if (img) img.style.opacity = '1';
      card.classList.remove('video-active');
      var btn = card.querySelector('.community-card__playbtn');
      if (btn) setPlayBtnState(btn, false);
    }
  
    // ── Hover (desktop only) ─────────────────────────────────────────────────
    if (window.matchMedia('(hover: hover)').matches) {
      console.log('Setting up hover events for desktop');
      var allCards = track.querySelectorAll('.community-card');
      console.log('Found cards:', allCards.length);
      allCards.forEach(function(card, index) {
        card.addEventListener('mouseenter', function () {
          console.log('Mouse entered card', index);
          var video = card.querySelector('.community-card__video-layer');
          if (!video) {
            console.log('No video in card', index);
            return;
          }
          
          // Only auto-play on hover if not manually controlled
          var btn = card.querySelector('.community-card__playbtn');
          var manuallyPaused = btn && btn.getAttribute('data-playing') === 'false' && card.classList.contains('video-active');
          
          if (!manuallyPaused) {
            showVideo(card);
          }
        });
        
        card.addEventListener('mouseleave', function () {
          console.log('Mouse left card', index);
          // Don't hide if user manually playing
          var btn = card.querySelector('.community-card__playbtn');
          var manuallyPlaying = btn && btn.getAttribute('data-playing') === 'true';
          
          if (!manuallyPlaying) {
            hideVideo(card);
          }
        });
      });
    } else {
      console.log('Hover not supported, skipping hover events');
    }
  
    // ── Play / Pause button click ────────────────────────────────────────────
    var allCards = track.querySelectorAll('.community-card');
    console.log('Setting up click events for', allCards.length, 'cards');
    allCards.forEach(function(card, index) {
      var btn = card.querySelector('.community-card__playbtn');
      if (!btn) {
        console.log('No button in card', index);
        return;
      }
      
      console.log('Adding click listener to button in card', index);
      btn.addEventListener('click', function (e) {
        console.log('Button clicked in card', index);
        e.preventDefault();
        e.stopPropagation();
        
        var video = card.querySelector('.community-card__video-layer');
        if (!video) {
          console.log('No video found when button clicked');
          return;
        }
    
        var isPlaying = btn.getAttribute('data-playing') === 'true';
        console.log('Current playing state:', isPlaying);
        if (isPlaying) {
          // Pause the video
          video.pause();
          setPlayBtnState(btn, false);
          console.log('Video paused');
        } else {
          // Play the video
          console.log('Attempting to play video');
          showVideo(card);
        }
      });
    });
  
  })();
</script>

{% schema %}
  {
    "name": "Testimonials — Community",
    "settings": [
      {
        "type": "header",
        "content": "Section"
      },
      {
        "type": "color",
        "id": "background_color",
        "label": "Background Color",
        "default": "#f5f1ed"
      },
      {
        "type": "header",
        "content": "Left Column Text"
      },
      {
        "type": "text",
        "id": "eyebrow",
        "label": "Eyebrow Label",
        "default": "ECHMA & YOU"
      }, {
        "type": "text",
        "id": "heading",
        "label": "Heading",
        "default": "The Community"
      }, {
        "type": "textarea",
        "id": "body_text",
        "label": "Body Copy",
        "default": "Powered by real science, made for real life. Discover how our community are incorporating DUA™ into their daily routines."
      }, {
        "type": "header",
        "content": "Cards"
      }, {
        "type": "range",
        "id": "card_width",
        "label": "Card Width (px)",
        "min": 600,
        "max": 700,
        "step": 10,
        "default": 600
      }, {
        "type": "range",
        "id": "card_image_height",
        "label": "Card Image Height (px)",
        "min": 400,
        "max": 900,
        "step": 50,
        "default": 700,
        "unit": "px"
      }, {
        "type": "range",
        "id": "card_gap",
        "label": "Gap Between Cards (px)",
        "min": 8,
        "max": 32,
        "step": 2,
        "default": 14
      }, {
        "type": "header",
        "content": "Controls"
      }, {
        "type": "text",
        "id": "prev_label",
        "label": "Previous Button Aria Label",
        "default": "Previous"
      }, {
        "type": "text",
        "id": "next_label",
        "label": "Next Button Aria Label",
        "default": "Next"
      }
    ],
    "blocks": [
      {
        "type": "card",
        "name": "Community Card",
        "settings": [
          {
            "type": "image_picker",
            "id": "image",
            "label": "Portrait Image"
          },
          {
            "type": "text",
            "id": "fallback_image_url",
            "label": "Fallback Image URL",
            "info": "Used when no image is picked above. Paste a full CDN URL."
          },
          {
            "type": "text",
            "id": "hover_video_url",
            "label": "Hover Video URL",
            "info": "MP4 video that plays on hover. Paste a full CDN URL (e.g. Shopify CDN .mp4)."
          },
          {
            "type": "text",
            "id": "username",
            "label": "Username (without @)",
            "default": "polonaamy"
          }, {
            "type": "checkbox",
            "id": "is_playing",
            "label": "Show Pause Icon (playing state)",
            "default": false
          }, {
